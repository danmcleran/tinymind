# Example run outputs written to the example dir (not output/): loss curves,
# confusion matrices, decision surfaces, predictions, samples. Examples
# synthesize or download their data and regenerate these on every run; only
# committed input datasets are tracked, so keep the one that is.
examples/**/*.csv
examples/**/*.txt
!examples/energy_efficiency/ENB2012_data.csv

# qlearn unit-test serialized Q-table output
unit_test/qlearn/qtable.bin
unit_test/qlearn/qtable.txt

# Static-analysis artifacts (regenerated by `make tidy` / `bear`)
compile_commands.json
tidy-report.txt
misra-report.txt
scan-report/

# Fuzzing: ignore built harness binaries (no extension) but keep the sources.
fuzz/fuzz_*
!fuzz/fuzz_*.cpp
!fuzz/fuzz_*.h
# The seed + regression corpus IS committed -- it is the deterministic replay
# gate's input. Only the live crash reproducers dropped at fuzz/ root are noise.
fuzz/crash-*
fuzz/leak-*
fuzz/oom-*
fuzz/timeout-*

# Python bytecode from example plot scripts
__pycache__/
*.pyc

# Local matplotlib venv for rendering example plots (not part of the repo)
.venv-plot/

# graphify: machine-specific paths + regenerable caches.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/cost.json
graphify-out/cache/
graphify-out/FINDINGS_*.md
# Derived graph artifacts: regenerated from code by the Pages CI build and
# published to GitHub Pages, so they are no longer tracked (kept the repo from
# churning a new graph on every commit). Only the curated community labels
# (.graphify_labels.json) stay versioned -- the rebuild reads them to name
# clusters. Rebuild locally with `/graphify .` or the headless rebuild.
graphify-out/graph.json
graphify-out/graph.html
graphify-out/GRAPH_REPORT.md
graphify-out/manifest.json
graphify-out/2026-*/

# CI-published graph data copy (regenerated during Pages build)
docs/assets/knowledge-graph/graph.json
